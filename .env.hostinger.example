# =============================================================================
# .env de PRODUÇÃO — Hostinger (hospedagem compartilhada)
# =============================================================================
# 1. Copie este arquivo para .env no servidor
# 2. Preencha os valores marcados com PREENCHER
# 3. Gere APP_KEY: php artisan key:generate
# =============================================================================

APP_NAME="Adote um Estudante"
APP_ENV=production
APP_KEY=PREENCHER_RODE_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://PREENCHER_SEU_DOMINIO.com

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- MySQL (dados do hPanel → Bancos de dados MySQL) ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=PREENCHER_nome_do_banco
DB_USERNAME=PREENCHER_usuario_mysql
DB_PASSWORD=PREENCHER_senha_mysql

# Hostinger: DB_HOST quase sempre é "localhost"

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

MAIL_MAILER=log
MAIL_FROM_ADDRESS="admin@PREENCHER_SEU_DOMINIO.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
